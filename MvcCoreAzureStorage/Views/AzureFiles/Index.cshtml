@model List<string>

<h1 style="color:blue">Azure Storage Files</h1>

<p>
    <a asp-controller="AzureFiles" asp-action="UploadFIle">Upload Azure File</a>
</p>

@if(Model != null)
{
    <ul class="list-group">
        @foreach(string fileName in Model)
        {
            <li class="list-group-item">@fileName
                <a asp-controller="AzureFiles" asp-action="ReadFile" asp-route-filename="@fileName" class="btn btn-primary">Read</a>
                <a asp-controller="AzureFiles" asp-action="DeleteFile" asp-route-filename="@fileName" class="btn btn-danger">Delete</a>
            </li>
        }
    </ul>
}